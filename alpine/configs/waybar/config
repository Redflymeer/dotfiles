{
  "layer": "top",
  "position": "top",
  "height": 24,
  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock", "sway/window"],
  "modules-right": ["custom/wofi","tray", "network", "bluetooth"],
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true
  },
  "clock": {
    "format": "{:%H:%M}",
    "interval": 1
  },
  "custom/wofi": {
    "format": " Wofi {}",
    "on-click": "wofi --show drun"
  },
  "tray": {
    "icon-size": 15,
    "spacing": 15,
    "show-passive-items": true
  },
  "bluetooth": {
    "format": " BT {status} ",
    "on-click": "blueman-manager"
  },
  "network": {
    "on-click": "kitty net-tool"
  }
}
